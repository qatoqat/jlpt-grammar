          { "id": "n3-you-ni-suru", "point": "Make / Change into", "jp": "～ようにする (you ni suru)", "meaning": "Make an effort to become...", "example": "毎日練習するようにしている。<span>Trying to practice every day.</span>" },
          { "id": "n3-you-ni-mieru", "point": "Looks like / Seems", "jp": "～ように見える (you ni mieru)", "meaning": "It looks like...", "example": "雨が降るように見える。<span>It looks like it's raining.</span>" },
          { "id": "n3-koto-ni-naru", "point": "Result / Decision", "jp": "～ことになる (koto ni naru)", "meaning": "It results in...", "example": "来月、帰国することになった。<span>It resulted in me returning home next month.</span>" }
