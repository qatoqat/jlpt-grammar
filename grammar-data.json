          { "id": "n2-chiottomo-nai", "point": "Not at all", "jp": "～ちっとも～ない (chitto mo ~ nai)", "meaning": "Not at all; not in the least.", "example": "ちっとも疲れていない。<span>Not tired at all.</span>" },
          { "id": "n2-to-shite-mo", "point": "Even if (assumption)", "jp": "～としても (toshite mo)", "meaning": "Even if we assume...", "example": "冗談としても、言いすぎだ。<span>Even as a joke, that's too much.</span>" }
