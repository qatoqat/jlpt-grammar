          { "id": "n3-kuse-ni", "point": "Even though / Despite", "jp": "～くせに (kuse ni)", "meaning": "Even though; despite (blaming).", "example": "知っているくせに教えない。<span>Even though you know, you won’t teach me.</span>" },
          { "id": "n3-mama", "point": "Just as is", "jp": "～まま (mama)", "meaning": "Leave in a state; as it is.", "example": "眼鏡をかけたまま寝る。<span>Sleep with glasses on.</span>" },
          { "id": "n3-maru-de", "point": "As if", "jp": "～まるで～ようだ (maru de ~ you da)", "meaning": "Just as if; like.", "example": "まるで夢のようだ。<span>It’s just like a dream.</span>" },
          { "id": "n3-kawari-ni", "point": "Instead of", "jp": "～代わりに (kawari ni)", "meaning": "Instead of.", "example": "私の代わりに行く。<span>Go in my place.</span>" },
          { "id": "n3-nagara-mo", "point": "While / Although", "jp": "～ながらも (nagara mo)", "meaning": "While/although ….", "example": "貧乏ながらも幸せだ。<span>While poor, (I’m) happy.</span>", "refs": ["n4-nagara"] },
          { "id": "n3-furi-o-suru", "point": "Pretend", "jp": "～ふりをする (furi o suru)", "meaning": "Pretend to be/do.", "example": "知らないふりをする。<span>Pretend not to know.</span>" },
          { "id": "n3-muki", "point": "Suitable for", "jp": "～向き (muki)", "meaning": "Suitable for.", "example": "初心者向き。<span>Suitable for beginners.</span>" },
          { "id": "n3-darake", "point": "Full of / All over", "jp": "～だらけ (darake)", "meaning": "Full of (often negative).", "example": "間違いだらけ。<span>Full of mistakes.</span>" }
