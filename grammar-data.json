          { "id": "n2-wake-dewa-nai", "point": "Not the case", "jp": "～わけではない (wake dewa nai)", "meaning": "Not necessarily; not entirely the case.", "example": "反対というわけではない。<span>I’m not necessarily opposed.</span>" },
          { "id": "n2-mono-dakara", "point": "Because (excuse)", "jp": "～ものだから (mono dakara)", "meaning": "Because; giving a reason/excuse.", "example": "遅れたものだから、ごめんなさい。<span>Sorry I’m late—because (something happened).</span>" },
