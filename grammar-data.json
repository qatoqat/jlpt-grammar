          { "id": "n3-ba-ii", "point": "Should do", "jp": "～ばいい (ba ii)", "meaning": "You should just do ….", "example": "分からない時、人に聞けばいい。<span>If you don’t understand, you should just ask someone.</span>" },
          { "id": "n3-ba-yokatta", "point": "Should have done", "jp": "～ばよかった (ba yokatta)", "meaning": "It would have been better if ….", "example": "もっと早く行けばよかった。<span>I should have gone earlier.</span>" },
          { "id": "n3-hodo", "point": "To the extent that", "jp": "～ほど (hodo)", "meaning": "To the extent that; so much that.", "example": "驚くほど速い。<span>Surprisingly fast.</span>" },
          { "id": "n3-hodo-nai", "point": "Not as … as", "jp": "～ほど～ない (hodo ~ nai)", "meaning": "Not as X as Y.", "example": "去年ほど寒くない。<span>Not as cold as last year.</span>" },
          { "id": "n3-donna-ni-temo", "point": "No matter how much", "jp": "～どんなに～ても (donna ni ~ temo)", "meaning": "No matter how ….", "example": "どんなに忙しくても電話する。<span>No matter how busy I am, I’ll call.</span>" },
          { "id": "n3-bakari-de-naku", "point": "Not only… but also", "jp": "～ばかりでなく (bakari de naku)", "meaning": "Not only … but also ….", "example": "肉ばかりでなく、野菜も食べる。<span>Not only meat, but also vegetables.</span>", "refs": ["n4-bakari-only"] },
          { "id": "n3-ippou-de", "point": "On one hand… on the other", "jp": "～一方で (ippou de)", "meaning": "On the other hand.", "example": "一方で、賛成の人もいる。<span>On the other hand, there are people who agree.</span>", "refs": ["n3-ippou-da"] },
          { "id": "n3-ippou-da", "point": "More and more", "jp": "～一方だ (ippou da)", "meaning": "Continues to ….", "example": "問題は複雑になる一方だ。<span>Problems are getting more and more complex.</span>", "refs": ["n3-ippou-de"] },
          { "id": "n3-ni-tsurete", "point": "As / In proportion to", "jp": "～につれて (ni tsurete)", "meaning": "As; in proportion to.", "example": "年をとるにつれて、目が悪くなった。<span>As I got older, my eyesight got worse.</span>" }
