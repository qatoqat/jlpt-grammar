          { "id": "n2-bakari-approx", "point": "Approximately", "jp": "～ばかり (bakari)", "meaning": "About; approximately.", "example": "1時間ばかり待った。<span>Waited about an hour.</span>", "refs": ["n4-bakari-approx"] },
          { "id": "n2-rashii", "point": "Typical of / -like", "jp": "～らしい (rashii)", "meaning": "Typical of; hearsay.", "example": "彼らしい言葉だ。<span>That is very like him.</span>" },
          { "id": "n2-ppoi", "point": "Seeming / -like", "jp": "～っぽい (ppoi)", "meaning": "Look like / tendency.", "example": "忘れっぽい。<span>Forgetful.</span>" },
          { "id": "n2-gimi", "point": "Slight tinge of", "jp": "～ぎみ (gimi)", "meaning": "A little bit of / tinge of.", "example": "疲れぎみだ。<span>Looks a bit tired.</span>" },
          { "id": "n2-nari", "point": "Apparent / Such as", "jp": "～なり (nari)", "meaning": "Or something like that.", "example": "彼は来るなり来ないなりだ。<span>Whether he comes or not is up in the air.</span>" },
          { "id": "n2-kizuku", "point": "Remains / Traces", "jp": "～きざす (kizuku)", "meaning": "To leave traces of; remains.", "example": "生活の跡が残されている。<span>Traces of life remain.</span>" }
