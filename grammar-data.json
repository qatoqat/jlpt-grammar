          { "id": "n3-beki-dewa-nai", "point": "Should not", "jp": "～べきではない (beki dewa nai)", "meaning": "Should not do.", "example": "嘘をつくべきではない。<span>You should not lie.</span>" },
          { "id": "n3-koto-da", "point": "Should (advice)", "jp": "～ことだ (koto da)", "meaning": "You should do ….", "example": "健康のために寝ることだ。<span>You should sleep for your health.</span>" },
          { "id": "n3-mono-da", "point": "Emotional truth / Should", "jp": "～ものだ (mono da)", "meaning": "It is natural that...", "example": "時間は経つのが早いものだ。<span>Time flies.</span>" },
          { "id": "n3-gachi", "point": "Tend to", "jp": "～がち (gachi)", "meaning": "Tends to be/do (often negative).", "example": "遅れがちだ。<span>Tends to be late.</span>" },
          { "id": "n3-gatai", "point": "Hard to", "jp": "～がたい (gatai)", "meaning": "Hard to (emotionally).", "example": "信じがたい。<span>Hard to believe.</span>" },
          { "id": "n3-kiri", "point": "Only just / Once", "jp": "～きり (kiri)", "meaning": "Only once; ever since.", "example": "一度きり会わない。<span>Meet only once.</span>", "refs": ["n3-kiru"] },
