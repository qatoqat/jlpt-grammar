          { "id": "n3-kirenai", "point": "Can’t finish", "jp": "～切れない (kirenai)", "meaning": "Can’t finish; too much.", "example": "食べきれない。<span>Can’t finish eating.</span>" },
          { "id": "n3-kesshite", "point": "Never", "jp": "～決して～ない (kesshite ~ nai)", "meaning": "Never; by no means.", "example": "決して忘れない。<span>I will never forget.</span>" },
          { "id": "n3-betsu-ni", "point": "Not really", "jp": "～べつに～ない (betsu ni ~ nai)", "meaning": "Not particularly; not really.", "example": "別に好きじゃない。<span>Not particularly fond.</span>" },
