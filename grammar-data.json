{
  "n5": {
    "color": "#27AE60",
    "sections": [
      {
        "title": "Particles — Multiple Uses",
        "cards": [
          { "id": "n5-wa-topic", "point": "Topic Marker", "jp": "は (wa)", "meaning": "Marks the topic; “as for…”", "example": "わたしは学生です。<span>I am a student.</span>", "refs": ["n5-wa-contrast"] },
          { "id": "n5-wa-contrast", "point": "Contrast Marker", "jp": "は (wa)", "meaning": "Implies contrast with other options.", "example": "肉は食べますが、魚は食べません。<span>I eat meat, but I don’t eat fish.</span>", "refs": ["n5-wa-topic"] },
          { "id": "n5-ga-subject", "point": "Subject Marker", "jp": "が (ga)", "meaning": "Marks the subject (focus/emphasis).", "example": "これが本です。<span>This is the book (the one that is).</span>", "refs": ["n5-ga-but"] },
          { "id": "n5-ga-but", "point": "But / However", "jp": "が (ga)", "meaning": "Connects clauses with contrast (formal).", "example": "すみませんが、行けません。<span>Sorry, but I can’t go.</span>", "refs": ["n5-ga-subject"] },
          { "id": "n5-o-obj", "point": "Object Marker", "jp": "を (o)", "meaning": "Marks the object of an action.", "example": "ご飯を食べる。<span>Eat a meal.</span>" },
          { "id": "n5-ni-dir", "point": "Direction / Destination", "jp": "に (ni)", "meaning": "To; towards (destination).", "example": "日本に行く。<span>Go to Japan.</span>", "refs": ["n5-ni-time", "n5-ni-exist"] },
          { "id": "n5-ni-time", "point": "Time (specific)", "jp": "に (ni)", "meaning": "At a specific time.", "example": "7時に起きる。<span>Wake up at 7.</span>", "refs": ["n5-ni-dir"] },
          { "id": "n5-ni-exist", "point": "Existence (animate)", "jp": "に (ni) + いる", "meaning": "Indicates location of animate existence.", "example": "庭に猫がいる。<span>There is a cat in the garden.</span>", "refs": ["n5-ga-aru"] },
          { "id": "n5-ni-indirect", "point": "Indirect Object (Receiver)", "jp": "に (ni)", "meaning": "Marks the recipient in giving/teaching verbs.", "example": "友達に本をあげる。<span>Give a book to a friend.</span>", "refs": ["n5-ni-dir"] },
          { "id": "n5-ni-purpose", "point": "Purpose (go to do)", "jp": "に (ni)", "meaning": "Go/come for the purpose of.", "example": "本を買いに行く。<span>Go to buy a book.</span>", "refs": ["n5-ni-dir"] },
          { "id": "n5-de-place", "point": "Place of Action", "jp": "で (de)", "meaning": "Where an action takes place (at/in).", "example": "図書館で勉強する。<span>Study at the library.</span>", "refs": ["n5-de-means", "n5-de-cause"] },
          { "id": "n5-de-means", "point": "Means / Method", "jp": "で (de)", "meaning": "By means of; with; using.", "example": "日本語で書く。<span>Write in Japanese.</span>", "refs": ["n5-de-place"] },
          { "id": "n5-de-total", "point": "Total Amount / Time Limit", "jp": "で (de)", "meaning": "In (total amount/time); within.", "example": "全部で1000円です。<span>It’s 1000 yen in total.</span>", "refs": ["n5-de-cause"] },
          { "id": "n5-de-cause", "point": "Reason / Cause", "jp": "で (de)", "meaning": "Because of (cause/reason).", "example": "病気で休む。<span>Rest because of illness.</span>", "refs": ["n5-node"] },
          { "id": "n5-no-possessive", "point": "Possessive / Modifier", "jp": "の (no)", "meaning": "'s; connects nouns.", "example": "私の本。<span>My book.</span>", "refs": ["n5-no-nominalizer"] },
          { "id": "n5-no-nominalizer", "point": "Verb Nominalizer", "jp": "の (no)", "meaning": "Turns a clause/verb into a noun.", "example": "走るのが好き。<span>I like running.</span>", "refs": ["n5-no-possessive"] },
          { "id": "n5-ka-question", "point": "Question Particle", "jp": "か (ka)", "meaning": "Makes a sentence a question.", "example": "行きますか。<span>Will you go?</span>", "refs": ["n5-ka-or"] },
          { "id": "n5-ka-or", "point": "Or (Choice)", "jp": "か (ka)", "meaning": "Or; indicates a choice or uncertainty.", "example": "コーヒーか紅茶。<span>Coffee or tea.</span>", "refs": ["n5-ka-question"] },
          { "id": "n5-kara-from", "point": "From (Origin)", "jp": "から (kara)", "meaning": "Starting point/origin.", "example": "日本から来た。<span>Came from Japan.</span>", "refs": ["n5-kara-because"] },
          { "id": "n5-kara-because", "point": "Because (Reason)", "jp": "から (kara)", "meaning": "Because, since (casual).", "example": "寒いから行かない。<span>I won’t go because it’s cold.</span>", "refs": ["n5-kara-from", "n5-node"] },
          { "id": "n5-made-until", "point": "Until / To (Extent)", "jp": "まで (made)", "meaning": "Up to (time/place); as far as.", "example": "5時まで待つ。<span>Wait until 5.</span>", "refs": ["n4-made-ni"] },
          { "id": "n5-e-direction", "point": "Direction (towards)", "jp": "へ (e)", "meaning": "Towards (directional emphasis).", "example": "学校へ行く。<span>Go towards school.</span>", "refs": ["n5-ni-dir"] },
          { "id": "n5-to-and", "point": "And / With", "jp": "と (to)", "meaning": "And (listing nouns); with.", "example": "友達と行く。<span>Go with a friend.</span>" },
          { "id": "n5-mo-also", "point": "Also / Too", "jp": "も (mo)", "meaning": "Also; too; as well.", "example": "私も行く。<span>I’m going too.</span>" },
          { "id": "n5-ya", "point": "And (partial list)", "jp": "や (ya)", "meaning": "And; non-exhaustive list.", "example": "リンゴやミカン。<span>Apples, oranges, etc.</span>" },
          { "id": "n5-yo-ne", "point": "Sentence Enders", "jp": "よ / ね (yo / ne)", "meaning": "Emphasis / Agreement.", "example": "いい天気ですね。<span>It's nice weather, isn't it?</span>" }
        ]
      },
      {
        "title": "Copula & Basic Sentences",
        "cards": [
          { "id": "n5-desu", "point": "To be (polite)", "jp": "です (desu)", "meaning": "Is/are/am (polite copula).", "example": "学生です。<span>I am a student.</span>" },
          { "id": "n5-da", "point": "To be (casual)", "jp": "だ (da)", "meaning": "Is/are/am (plain copula).", "example": "雨だ。<span>It’s raining.</span>" },
          { "id": "n5-ja-nai", "point": "Is not (polite)", "jp": "じゃない / ではない (ja nai / de wa nai)", "meaning": "Is not (negative of です/だ).", "example": "学生ではない。<span>Not a student.</span>" },
          { "id": "n5-deshou", "point": "Probably / I think", "jp": "でしょう (deshou)", "meaning": "Probably; I think (polite guess).", "example": "雨でしょう。<span>It will probably rain.</span>" }
        ]
      },
      {
        "title": "Verbs (Basic Forms)",
        "cards": [
          { "id": "n5-masu", "point": "Polite Present/Future", "jp": "～ます (masu)", "meaning": "Will do / do (polite non-past).", "example": "行きます。<span>Will go.</span>" },
          { "id": "n5-mashita", "point": "Polite Past", "jp": "～ました (mashita)", "meaning": "Did (polite past).", "example": "行きました。<span>Went.</span>" },
          { "id": "n5-masen", "point": "Polite Negative", "jp": "～ません (masen)", "meaning": "Will not do / do not (polite).", "example": "行きません。<span>Won’t go.</span>" },
          { "id": "n5-nai", "point": "Plain Negative", "jp": "～ない (nai)", "meaning": "Do not (plain negative).", "example": "行かない。<span>Won't go.</span>" },
          { "id": "n5-nakatta", "point": "Plain Past Negative", "jp": "～なかった (nakatta)", "meaning": "Did not (plain past negative).", "example": "行かなかった。<span>Didn't go.</span>" },
          { "id": "n5-te", "point": "Te-form (connect/do)", "jp": "～て (te)", "meaning": "Connects actions; basis for requests.", "example": "本を読んで、寝る。<span>Read a book and sleep.</span>" },
          { "id": "n5-te-kudasai", "point": "Request (Please do)", "jp": "～てください (te kudasai)", "meaning": "Please do …", "example": "座ってください。<span>Please sit down.</span>" },
          { "id": "n5-te-mo-ii", "point": "Permission (May)", "jp": "～てもいい (te mo ii)", "meaning": "It is okay to do…", "example": "入ってもいい。<span>You may enter.</span>" },
          { "id": "n5-te-wa-ikenai", "point": "Must not", "jp": "～てはいけない (te wa ikenai)", "meaning": "Must not do …", "example": "ここに入ってはいけない。<span>Must not enter here.</span>" },
          { "id": "n5-te-iru", "point": "Progressive / State", "jp": "～ている (te iru)", "meaning": "Doing now; resulting state.", "example": "今食べている。<span>Eating now.</span>" },
          { "id": "n5-te-aru", "point": "State (Inanimate)", "jp": "～てある (te aru)", "meaning": "State of being (done for a purpose).", "example": "窓が開けてある。<span>The window is left open (on purpose).</span>" },
          { "id": "n5-te-oku", "point": "Do in advance", "jp": "～ておく (te oku)", "meaning": "Do something for later.", "example": "予約しておく。<span>Make a reservation in advance.</span>" },
          { "id": "n5-te-miru", "point": "Try doing", "jp": "～てみる (te miru)", "meaning": "Try doing and see.", "example": "日本の映画を見てみる。<span>Try watching a Japanese movie.</span>" },
          { "id": "n5-te-kara", "point": "After doing", "jp": "～てから (te kara)", "meaning": "After doing X.", "example": "ご飯を食べてから行く。<span>Go after eating.</span>" },
          { "id": "n5-naide-kudasai", "point": "Please don’t", "jp": "～ないでください (naide kudasai)", "meaning": "Please don’t do …", "example": "入らないでください。<span>Please don’t enter.</span>" },
          { "id": "n5-tai", "point": "Want to do", "jp": "～たい (tai)", "meaning": "Want to do …", "example": "行きたい。<span>Want to go.</span>" },
          { "id": "n5-ta-koto-ga-aru", "point": "Have done before", "jp": "～たことがある (ta koto ga aru)", "meaning": "Have done (experience).", "example": "日本に行ったことがある。<span>Have been to Japan.</span>" },
          { "id": "n5-tsumori-da", "point": "Plan / Intend to", "jp": "～つもりだ (tsumori da)", "meaning": "Plan to; intend to.", "example": "行くつもりだ。<span>Plan to go.</span>" }
        ]
      },
      {
        "title": "Adjectives",
        "cards": [
          { "id": "n5-i-adj", "point": "i-adj present", "jp": "～い (i)", "meaning": "Is [adj].", "example": "大きい。<span>Big.</span>" },
          { "id": "n5-i-adj-neg", "point": "i-adj negative", "jp": "～くない (kunai)", "meaning": "Is not [adj].", "example": "大きくない。<span>Not big.</span>" },
          { "id": "n5-i-adj-past", "point": "i-adj past", "jp": "～かった (katta)", "meaning": "Was [adj].", "example": "大きかった。<span>Was big.</span>" },
          { "id": "n5-i-adj-past-neg", "point": "i-adj past negative", "jp": "～くなかった (kunakatta)", "meaning": "Was not [adj].", "example": "大きくなかった。<span>Was not big.</span>" },
          { "id": "n5-na-adj", "point": "na-adj present", "jp": "～な / だ (na / da)", "meaning": "Is [adj] (na-adj).", "example": "静かだ。<span>Quiet.</span>" },
          { "id": "n5-na-adj-neg", "point": "na-adj negative", "jp": "～じゃない (ja nai)", "meaning": "Is not [na-adj].", "example": "静かじゃない。<span>Not quiet.</span>" }
        ]
      },
      {
        "title": "Connectors & Others",
        "cards": [
          { "id": "n5-node", "point": "Because (softer)", "jp": "～ので (node)", "meaning": "Because, since (polite).", "example": "寒いので行かない。<span>Since it’s cold, I won’t go.</span>", "refs": ["n5-kara-because"] },
          { "id": "n5-kedo", "point": "But / However", "jp": "～けど / けれど (kedo / keredo)", "meaning": "But, however (casual).", "example": "安いけど、古い。<span>It’s cheap but old.</span>", "refs": ["n5-ga-but"] },
          { "id": "n5-yori", "point": "Comparison", "jp": "～より～のほうが (yori ~ no hou ga)", "meaning": "More X than Y.", "example": "歩くよりバスのほうが速い。<span>The bus is faster than walking.</span>" },
          { "id": "n5-ga-aru", "point": "Existence (inanimate)", "jp": "～がある (ga aru)", "meaning": "There is (a thing).", "example": "庭に木がある。<span>There is a tree in the yard.</span>", "refs": ["n5-ni-exist"] },
          { "id": "n5-ni-iku", "point": "Go / Come for Purpose", "jp": "～にいく / にくる (ni iku / ni kuru)", "meaning": "Go/come to do (verb).", "example": "服を買いに行く。<span>Go to buy clothes.</span>" },
          { "id": "n5-ni-suru", "point": "Decide on", "jp": "～にする (ni suru)", "meaning": "Decide to choose/make.", "example": "これにする。<span>I'll choose this one.</span>" },
          { "id": "n5-no-ga-suki", "point": "Likes doing", "jp": "～のが好き (no ga suki)", "meaning": "Like doing something.", "example": "音楽を聞くのが好き。<span>I like listening to music.</span>" }
        ]
      }
    ]
  },
  "n4": {
    "color": "#2980B9",
    "sections": [
      {
        "title": "Conditionals & Time",
        "cards": [
          { "id": "n4-ba", "point": "If (conditional)", "jp": "～ば (ba)", "meaning": "If … then ….", "example": "行けば、会える。<span>If you go, you can meet.</span>" },
          { "id": "n4-tara", "point": "When / If (after)", "jp": "～たら (tara)", "meaning": "When/if it happens ….", "example": "家に着いたら連絡する。<span>When I get home, I’ll contact you.</span>" },
          { "id": "n4-baai-wa", "point": "In the case that", "jp": "～場合は (baai wa)", "meaning": "In the event/ case that ….", "example": "雨の場合は中止だ。<span>In case of rain, it’s cancelled.</span>" },
          { "id": "n4-nara", "point": "If, in case", "jp": "～なら (nara)", "meaning": "If (topic/conditional).", "example": "京都なら、新幹線が便利だ。<span>If it’s Kyoto, the shinkansen is convenient.</span>" },
          { "id": "n4-ato-de", "point": "After, later", "jp": "～あとで (ato de)", "meaning": "After; later.", "example": "ご飯のあとで勉強する。<span>Study after the meal.</span>" },
          { "id": "n4-made-ni", "point": "By (deadline)", "jp": "～までに (made ni)", "meaning": "By (a certain time).", "example": "5時までに来て。<span>Come by 5 o’clock.</span>", "refs": ["n5-made-until"] },
          { "id": "n4-aida", "point": "While / During", "jp": "～間 (aida)", "meaning": "While; during.", "example": "映画の間、寝ていた。<span>Slept during the movie.</span>" },
          { "id": "n4-aida-ni", "point": "During (event)", "jp": "～間に (aida ni)", "meaning": "While; during (event happening).", "example": "夏休みの間に海へ行った。<span>Went to the sea during summer break.</span>" },
          { "id": "n4-nagara", "point": "While doing", "jp": "～ながら (nagara)", "meaning": "While (doing two things).", "example": "音楽を聴きながら勉強する。<span>Study while listening to music.</span>" },
          { "id": "n4-mae-ni", "point": "Before", "jp": "～前に (mae ni)", "meaning": "Before doing X.", "example": "寝る前に本を読む。<span>Read a book before sleeping.</span>" },
          { "id": "n4-toki", "point": "When / At the time", "jp": "～時 (toki)", "meaning": "When/At the time of.", "example": "子供の時、大阪に住んでいた。<span>Lived in Osaka when I was a child.</span>" },
          { "id": "n4-nai-de", "point": "Without doing", "jp": "～ないで (naide)", "meaning": "Without doing ….", "example": "朝ご飯を食べないで学校へ行く。<span>Go to school without eating breakfast.</span>" }
        ]
      },
      {
        "title": "Possibility, Ability & Necessity",
        "cards": [
          { "id": "n4-koto-ga-dekiru", "point": "Can do", "jp": "～ことができる (koto ga dekiru)", "meaning": "Can; be able to.", "example": "日本語を話すことができる。<span>Can speak Japanese.</span>" },
          { "id": "n4-rareru-potential", "point": "Potential Form", "jp": "～られる (rareru)", "meaning": "Can be done (potential verb).", "example": "この店で寿司が食べられる。<span>Can eat sushi at this shop.</span>" },
          { "id": "n4-nakereba-naranai", "point": "Must do", "jp": "～なければならない (nakereba naranai)", "meaning": "Must; have to.", "example": "勉強しなければならない。<span>Must study.</span>" },
          { "id": "n4-nakute-wa-ikenai", "point": "Must do (Strong)", "jp": "～なくてはいけない (nakute wa ikenai)", "meaning": "Must not / Ought not.", "example": "もっと努力しなくてはいけない。<span>Must try harder.</span>" },
          { "id": "n4-nakute-mo-ii", "point": "Don’t have to", "jp": "～なくてもいい (nakute mo ii)", "meaning": "Don’t have to; it’s okay not to.", "example": "行かなくてもいい。<span>You don’t have to go.</span>" },
          { "id": "n4-ga-hoshii", "point": "Want (something)", "jp": "～がほしい (ga hoshii)", "meaning": "Want something.", "example": "新しい車がほしい。<span>Want a new car.</span>" },
          { "id": "n4-ni-purpose", "point": "Purpose (go to do)", "jp": "～に (ni)", "meaning": "Go/come for the purpose of.", "example": "本を買いに行く。<span>Go to buy a book.</span>", "refs": ["n5-ni-dir"] }
        ]
      },
      {
        "title": "Likelihood, Guess & Concession",
        "cards": [
          { "id": "n4-kamoshirenai", "point": "Might / Maybe", "jp": "～かもしれない (kamoshirenai)", "meaning": "Might be; maybe.", "example": "雨かもしれない。<span>It might rain.</span>" },
          { "id": "n4-deshou", "point": "Probably / I think", "jp": "～でしょう (deshou)", "meaning": "Probably; I think (polite).", "example": "明日は晴れるでしょう。<span>It will probably be fine tomorrow.</span>" },
          { "id": "n4-hazu-da", "point": "Should be / Must be", "jp": "～はずだ (hazu da)", "meaning": "Should be; expected to be.", "example": "彼は来るはずだ。<span>He should come.</span>" },
          { "id": "n4-hazu-ga-nai", "point": "Cannot be", "jp": "～はずがない (hazu ga nai)", "meaning": "Cannot be; unlikely.", "example": "そんなはずがない。<span>That can’t be.</span>" },
          { "id": "n4-wake-janai", "point": "Not necessarily", "jp": "～わけではない (wake dewa nai)", "meaning": "It is not the case that...", "example": "この店は高いわけではない。<span>This shop isn't necessarily expensive.</span>" },
          { "id": "n4-noni", "point": "Although / Even though", "jp": "～のに (noni)", "meaning": "Despite; even though.", "example": "勉強したのに、失敗した。<span>Even though I studied, I failed.</span>", "refs": ["n5-node", "n5-ga-but"] },
          { "id": "n4-dake-de", "point": "Just by", "jp": "～だけで (dake de)", "meaning": "Just by doing ….", "example": "これだけでいい。<span>This alone is enough.</span>" },
          { "id": "n4-bakari-only", "point": "Only, nothing but", "jp": "～ばかり (bakari)", "meaning": "Only doing X; full of.", "example": "ゲームばかりしている。<span>Doing nothing but playing games.</span>", "refs": ["n4-bakari-approx"] },
          { "id": "n4-bakari-approx", "point": "Approximately (time/amount)", "jp": "～ばかり (bakari)", "meaning": "About; approximately.", "example": "1時間ばかり待った。<span>Waited about an hour.</span>", "refs": ["n4-bakari-only"] },
          { "id": "n4-mitai", "point": "Like / Similar", "jp": "～みたい (mitai)", "meaning": "Like; seems like (casual).", "example": "猫みたい。<span>Like a cat.</span>" },
          { "id": "n4-no-you", "point": "Like / Similar (formal)", "jp": "～ように / ～ような (no you ni / no you na)", "meaning": "Like; as if.", "example": "子どものようだ。<span>Like a child.</span>" },
          { "id": "n4-sou-da", "point": "Looks like (Visual)", "jp": "～そうだ (sou da)", "meaning": "Looks like (based on appearance).", "example": "雨が降りそうだ。<span>It looks like it will rain.</span>" }
        ]
      },
      {
        "title": "Actions & Changes",
        "cards": [
          { "id": "n4-te-miru", "point": "Try doing", "jp": "～てみる (te miru)", "meaning": "Try doing and see.", "example": "日本の映画を見てみる。<span>Try watching a Japanese movie.</span>" },
          { "id": "n4-te-oku", "point": "Do in advance", "jp": "～ておく (te oku)", "meaning": "Do something for later.", "example": "予約しておく。<span>Make a reservation in advance.</span>" },
          { "id": "n4-hajimeru", "point": "Start to", "jp": "～はじめる (hajimeru)", "meaning": "Begin to ….", "example": "雨が降り始めた。<span>It started to rain.</span>" },
          { "id": "n4-owaru", "point": "Finish / End", "jp": "～おわる (owaru)", "meaning": "To finish/come to an end (intransitive).", "example": "会議が終わった。<span>The meeting ended.</span>" },
          { "id": "n4-nikui", "point": "Difficult to", "jp": "～にくい (nikui)", "meaning": "Hard to ….", "example": "食べにくい。<span>Hard to eat.</span>" },
          { "id": "n4-yasui", "point": "Easy to", "jp": "～やすい (yasui)", "meaning": "Easy to ….", "example": "読みやすい。<span>Easy to read.</span>" },
          { "id": "n4-koto-ni-suru", "point": "Decide to", "jp": "～ことにする (koto ni suru)", "meaning": "Decide to ….", "example": "毎日走ることにする。<span>Decide to run every day.</span>" },
          { "id": "n4-koto-ni-naru", "point": "It has been decided", "jp": "～ことになる (koto ni naru)", "meaning": "It’s been decided that ….", "example": "来月、東京へ転勤することになった。<span>It’s been decided that I’ll transfer to Tokyo next month.</span>" },
          { "id": "n4-yoseru", "point": "Only / Nothing but", "jp": "～よりほかに～ない (yori hoka ni ~ nai)", "meaning": "Nothing but X.", "example": "勉強よりほかにすることがない。<span>I do nothing but study.</span>" },
          { "id": "n4-ni-totte", "point": "In terms of / For", "jp": "～にとって (ni totte)", "meaning": "For / In the eyes of.", "example": "私にとって、これは大切だ。<span>This is important to me.</span>" },
          { "id": "n4-ni-kan-ship", "point": "Regarding / Concerning", "jp": "～について (ni tsuite)", "meaning": "About / Concerning.", "example": "日本について話す。<span>Speak about Japan.</span>" }
        ]
      },
      {
        "title": "Giving & Receiving",
        "cards": [
          { "id": "n4-te-ageru", "point": "Give (Outwards)", "jp": "～てあげる (te ageru)", "meaning": "Do something for someone (outwards).", "example": "弟に本を読んであげる。<span>Read a book for my brother.</span>" },
          { "id": "n4-te-kureru", "point": "Give (Downwards)", "jp": "～てくれる (te kureru)", "meaning": "Someone does something for me.", "example": "田中さんが本を貸してくれた。<span>Tanaka-san lent me a book.</span>" },
          { "id": "n4-te-morau", "point": "Receive (Upwards)", "jp": "～てもらう (te morau)", "meaning": "Have someone do something for me.", "example": "先生に日本語を教えてもらう。<span>Have the teacher teach me Japanese.</span>" }
        ]
      },
      {
        "title": "Passive & Causative (Intro)",
        "cards": [
          { "id": "n4-rareru-passive", "point": "Passive Form", "jp": "～られる (rareru)", "meaning": "Is done by... (passive).", "example": "母に叱られた。<span>Was scolded by my mother.</span>" },
          { "id": "n4-saseru", "point": "Causative (Make do)", "jp": "～させる (saseru)", "meaning": "Make/Let someone do something.", "example": "子供に野菜を食べさせる。<span>Make the child eat vegetables.</span>" },
          { "id": "n4-sasareru", "point": "Causative Passive", "jp": "～させられる (saserareru)", "meaning": "Forced to do something.", "example": "飲みに行かさせられた。<span>Was forced to go drinking.</span>" }
        ]
      }
    ]
