          { "id": "n3-tame-ni", "point": "For the sake of / Result", "jp": "～ために (tame ni)", "meaning": "For...; Because of (often negative).", "example": "試験のために勉強する。<span>Study for the exam.</span>" },
          { "id": "n3-sei-de", "point": "Due to (Negative)", "jp": "～せいで (sei de)", "meaning": "Due to (negative result).", "example": "遅れたせいで遅刻した。<span>Was late due to the delay.</span>" },
